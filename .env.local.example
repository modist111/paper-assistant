# ============================================================
# AI 论文阅读助手 — 环境变量配置
# ============================================================
# 复制此文件为 .env.local 并填入你的真实值：
#   cp .env.local.example .env.local
# ============================================================

# ============================================================
# LLM 大语言模型 (问答生成)
# ============================================================
# 支持 OpenAI、DeepSeek 及任何兼容 /v1/chat/completions 的服务

# LLM API Key (如不设置，回退到 OPENAI_API_KEY)
LLM_API_KEY=sk-your-llm-key

# LLM API Base URL
# OpenAI 默认:  https://api.openai.com/v1
# DeepSeek:      https://api.deepseek.com
# 硅基流动:       https://api.siliconflow.cn/v1
# Ollama 本地:    http://localhost:11434/v1
# LLM_API_BASE_URL=https://api.openai.com/v1

# LLM 模型名
# OpenAI:        gpt-4o / gpt-4o-mini
# DeepSeek:      deepseek-chat (V3) / deepseek-reasoner (R1)
# 硅基流动:       deepseek-ai/DeepSeek-V3
LLM_MODEL=gpt-4o

# ============================================================
# Embedding 文本向量化
# ============================================================

# Embedding API Key (如不设置，回退到 OPENAI_API_KEY 再回退到 LLM_API_KEY)
# EMBEDDING_API_KEY=sk-your-embedding-key

# Embedding API Base URL (如不设置，回退到 OPENAI_API_BASE_URL)
# EMBEDDING_API_BASE_URL=https://api.openai.com/v1

# Embedding 模型 (默认 text-embedding-3-small, 1536d)
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# 通用 OpenAI Key (Embedding 和 LLM 共用的回退值)
# ============================================================
# 如果你 Embedding 和 LLM 都用 OpenAI，只需设置这一个
# 如果你 LLM 用 DeepSeek、Embedding 用 OpenAI，则单独设置上面的 LLM_API_KEY
OPENAI_API_KEY=sk-your-openai-key

# OpenAI API Base URL (Embedding 的默认回退值)
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# ============================================================
# Supabase (必需)
# ============================================================
# 从 Supabase Dashboard → Project Settings → API 获取

# Supabase 项目 URL (公开)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase 匿名密钥 (公开，受 RLS 限制)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Service Role 密钥 (机密，仅服务端使用)
# ⚠️ 此密钥绕过 RLS，永远不要暴露给客户端
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 可选参数
# ============================================================

# 文本分块参数 (默认值)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# 向量检索参数 (默认值)
# VECTOR_SEARCH_LIMIT=5
# VECTOR_SIMILARITY_THRESHOLD=0.7
